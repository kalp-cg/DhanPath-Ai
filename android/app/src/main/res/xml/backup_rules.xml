<!--
    Full backup rules for pre-Android 12 (API < 31).
    DhanPath is a finance app — exclude all sensitive data from backup.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
