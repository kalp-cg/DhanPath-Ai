MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=dhanpath
JWT_SECRET=change_this_to_a_long_random_string
NEXT_PUBLIC_APP_NAME=DhanPath AI

# Stripe (required for paid plan checkout)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# AI Advisor (required for AI chat generation)
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile

# Optional but recommended for absolute URL generation in emails/exports
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional for scheduled CA pack cron endpoint
CA_PACK_CRON_SECRET=change_this_to_random_secret
